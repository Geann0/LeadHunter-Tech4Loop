{
  "name": "leadhunter-tech4loop",
  "description": "LeadHunter Pro - Ferramenta automática de extração e análise de leads",
  "author": "Tech4Loop",
  "license": "Proprietary",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-packager . LeadHunter-Pro --platform=win32 --arch=x64 --out=production-build --overwrite --no-asar --icon=public/icon.ico",
    "build:portable": "tsc && vite build && electron-packager . LeadHunter-Pro --platform=win32 --arch=x64 --out=dist_installer --overwrite --no-asar --icon=public/icon.ico",
    "build:installer": "tsc && vite build && electron-builder --publish never",
    "dist": "electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "levenshtein": "^1.0.5",
    "lucide-react": "^0.312.0",
    "playwright": "^1.57.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/levenshtein": "^1.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "electron-packager": "^17.1.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.2.2",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.tech4loop.leadhunter",
    "productName": "LeadHunter Pro",
    "directories": {
      "output": "dist_installer",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/playwright-core/**/*",
      "node_modules/playwright/**/*",
      "node_modules/ffmpeg-static/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeader": "public/icon.ico",
      "installerSidebar": "public/installerSidebar.bmp",
      "uninstallerSidebar": "public/installerSidebar.bmp",
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LeadHunter Pro"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/playwright-core/**/*",
      "node_modules/playwright/**/*",
      "node_modules/ffmpeg-static/**/*",
      "dist-electron/preload.cjs"
    ]
  }
}
