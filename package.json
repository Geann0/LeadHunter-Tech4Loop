{
  "name": "leadhunter-tech4loop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-packager . LeadHunter-Pro --platform=win32 --arch=x64 --out=production-build --overwrite --asar --icon=public/icon.ico",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.312.0",
    "playwright": "^1.57.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.tech4loop.leadhunter",
    "productName": "LeadHunter Pro",
    "directories": {
      "output": "production-build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/playwright-core/**/*",
      "node_modules/playwright/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": "dir",
      "icon": "public/icon.ico"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/playwright-core/**/*",
      "node_modules/playwright/**/*",
      "dist-electron/preload.cjs"
    ]
  }
}
